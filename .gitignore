# Project-specific reference materials (not part of the template)
refs/*
!refs/README.md

# Project-specific plans, reports, and notes (generated per-paper)
plans/*
!plans/.gitkeep

reports/*
!reports/.gitkeep

notes/*
!notes/.gitkeep

# STATUS.md and CLAUDE.md content are paper-specific, but we keep the templates
# (the template versions in this repo are overwritten per-paper after cloning)
STATUS.md
CLAUDE.md